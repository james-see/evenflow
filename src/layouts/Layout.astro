---
import '../styles/global.css';

const navLinks = [
  { href: '/', label: 'Dashboard' },
  { href: '/services', label: 'Services' },
  { href: '/budgets', label: 'Budgets' },
  { href: '/triggers', label: 'Triggers' },
  { href: '/settings', label: 'Settings' },
];

const { pathname } = Astro.url;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Evenflow — Free and open source cloud budget management. Runs entirely in your browser." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>Evenflow — Cloud Budget Management</title>
  </head>
  <body class="h-full">
    <div class="flex h-full">
      <!-- Sidebar -->
      <aside class="hidden w-64 shrink-0 border-r border-slate-800 bg-slate-900 md:flex md:flex-col">
        <div class="flex items-center gap-2 px-6 py-5">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-evenflow-600 font-bold text-white">E</div>
          <span class="text-lg font-semibold text-white">Evenflow</span>
        </div>
        <nav class="flex-1 px-3 py-2">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`block rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
                pathname === link.href
                  ? 'bg-evenflow-600 text-white'
                  : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100'
              }`}
            >
              {link.label}
            </a>
          ))}
        </nav>
        <div class="border-t border-slate-800 px-6 py-4 text-xs text-slate-500">
          <p>Open source · AGPL-3.0</p>
          <p class="mt-1">100% browser-based · No server</p>
        </div>
      </aside>

      <!-- Main -->
      <main class="flex-1 overflow-y-auto">
        <!-- Mobile header -->
        <div class="flex items-center justify-between border-b border-slate-800 bg-slate-900 px-4 py-3 md:hidden">
          <div class="flex items-center gap-2">
            <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-evenflow-600 font-bold text-white text-sm">E</div>
            <span class="font-semibold text-white">Evenflow</span>
          </div>
        </div>
        <div class="flex gap-1 overflow-x-auto border-b border-slate-800 bg-slate-900 px-2 md:hidden">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`whitespace-nowrap rounded-lg px-3 py-2 text-sm ${
                pathname === link.href
                  ? 'bg-evenflow-600 text-white'
                  : 'text-slate-400'
              }`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="px-6 py-8 md:px-8 md:py-10">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>