---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <h1 class="text-2xl font-bold text-white">Settings</h1>
  <p class="mt-1 text-sm text-slate-400">Database management, export/import, and configuration.</p>
  <div class="mt-6 space-y-4">
    <div class="card">
      <h2 class="text-lg font-semibold text-white">Database</h2>
      <p class="mt-2 text-sm text-slate-400">
        Your data is stored locally in your browser via OPFS (Origin Private File System).
        No data is sent to any server.
      </p>
      <div class="mt-4 flex gap-2">
        <button id="export-btn" class="btn-primary">Export Database</button>
        <button id="reset-btn" class="btn-danger">Reset All Data</button>
      </div>
    </div>
    <div class="card">
      <h2 class="text-lg font-semibold text-white">About Evenflow</h2>
      <p class="mt-2 text-sm text-slate-400">
        Evenflow is a free and open source cloud budget management tool that runs entirely in your browser.
        Powered by SQLite WebAssembly with OPFS persistence — no server, no database, no cloud costs.
      </p>
      <p class="mt-2 text-sm text-slate-400">
        Licensed under AGPL-3.0. Source code at <a href="https://github.com/james-see/evenflow" class="text-evenflow-400 hover:text-evenflow-300">github.com/james-see/evenflow</a>.
      </p>
    </div>
  </div>
</Layout>