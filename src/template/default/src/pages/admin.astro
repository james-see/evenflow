---
import Layout from '../layouts/Layout.astro';
import Admin from '../components/Admin.svelte';
---

<script>
  const token = typeof localStorage !== 'undefined' ? localStorage.getItem('evenflow_token') : null;
  if (!token) {
    window.location.replace('/login');
  }
</script>

<Layout>
  <h1 class="text-2xl font-bold mb-6">CMS Admin</h1>
  <Admin client:only="svelte" />
</Layout>